{
  "name": "transporthu",
  "version": "1.0.0",
  "description": "TransportHU Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:all": "electron-builder"
  },
  "build": {
    "appId": "com.transporthu.desktop",
    "productName": "TransportHU",
    "icon": "icon.png",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.travel"
    },
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  }
}
